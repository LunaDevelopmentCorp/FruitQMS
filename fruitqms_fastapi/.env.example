# FruitQMS FastAPI Configuration
# Copy this to .env and adjust values

# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./fruitqms.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/fruitqms

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# FruitPak Integration (optional — leave all empty to disable)
# Local dev: http://localhost:3000 | Production: https://api.fruitpak.com (AWS)
FRUITPAK_API_URL=
# Dedicated QMS service user credentials (create in FruitPak with batch.read, batch.write, grower.read)
FRUITPAK_EMAIL=
FRUITPAK_PASSWORD=
FRUITPAK_TIMEOUT_SECONDS=10
FRUITPAK_POLL_INTERVAL_MINUTES=10

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Debug mode
DEBUG=true
